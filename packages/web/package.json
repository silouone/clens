{
  "name": "@clens/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "cLens web dashboard — SolidJS + Hono",
  "exports": {
    "./server": "./src/server/index.ts"
  },
  "scripts": {
    "dev:api": "bun --watch run src/server/index.ts",
    "dev:api:global": "bun --watch run src/server/index.ts --global",
    "dev:web": "vite dev",
    "build": "vite build",
    "test": "bun test test/",
    "test:api": "bun test test/",
    "lint": "bunx biome check src/ test/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@silou/clens": "workspace:*",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@kobalte/core": "^0.13.0",
    "@solidjs/router": "^0.15.0",
    "diff2html": "^3.4.0",
    "hono": "^4.0.0",
    "lucide-solid": "^0.577.0",
    "snarkdown": "^2.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.10.0"
  }
