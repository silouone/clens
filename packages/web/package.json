{
  "name": "@clens/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "cLens web dashboard — SolidJS + Hono",
  "exports": {
    "./server": "./src/server/index.ts"
  },
  "scripts": {
    "dev:api": "bun --watch run src/server/index.ts",
    "dev:web": "vite dev",
    "build": "vite build",
    "test": "bun test test/ && vitest run",
    "test:api": "bun test test/",
    "test:vitest": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clens/cli": "workspace:*",
    "@kobalte/core": "^0.13.0",
    "@solidjs/router": "^0.15.0",
    "diff2html": "^3.4.0",
    "hono": "^4.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.10.0",
    "vitest": "^2.0.0"
  }
}
